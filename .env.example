FLASK_ENV=development
FLASK_APP=run.py

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-secret-key
JWT_SECRET_KEY=change-me-jwt-secret-key

# MySQL connection — use these vars (password is safe with special chars like @)
DB_USER=root
DB_PASSWORD=YOUR_PASSWORD
DB_HOST=localhost
DB_PORT=3306
DB_NAME=kyff_practice_db
DB_TEST_NAME=kyff_practice_test

# Razorpay (test keys from dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
