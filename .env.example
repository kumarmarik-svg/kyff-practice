FLASK_ENV=development
FLASK_APP=run.py

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-secret-key
JWT_SECRET_KEY=change-me-jwt-secret-key

# MySQL connection
DATABASE_URL=mysql+pymysql://root:password@localhost/kyff_dev
TEST_DATABASE_URL=mysql+pymysql://root:password@localhost/kyff_test

# Razorpay (test keys from dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
